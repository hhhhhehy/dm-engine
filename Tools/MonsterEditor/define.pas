unit define;
interface
uses Windows,Classes,SysUtils,stdctrls;
type
  TBase = record
    ClassName:String;
    ViewName:String;
    OutView:Word;
    Level:Byte;
    Race:Byte;
    NameColor:Byte;
    Raceimg: Byte;
    OutView_h:integer;
  end;
  TProp = record
    Hp:word;
    Mp:word;
    Hit:Byte;
    Speed:Byte;
    Ac1:Byte;
    Ac2:Byte;
    Dc1:Byte;
    Dc2:Byte;
    Mac1:Byte;
    Mac2:Byte;
    Mc1:Byte;
    Mc2:Byte;
    AiDelay:WORD;
    WalkDelay:WORD;
    Exp:DWORD;
    RecoverHp:WORD;
    RecoverHpTime:WORD;
    RecoverMp:WORD;
    RecoverMpTime:WORD;
  end;
  TSpecialProp = record
    pFlag:DWORD;
    CallRate:Byte;
    AntSoulWall:Byte;
    AntTrouble:Byte;
    AntHolyWord:Byte;
    MonsterName:string[64];
  end;

  TChangeSituation = record
    Situation:integer;
    Param:integer;
  end;

  TAiAttack = record
    AttackStyle:Byte;
    DamageStyle:Byte;
    DamageType:Byte;
    AppendEffect:Byte;
    AppendRate:Byte;
    AttackDistance:Byte;
    DamageRange:Byte;
    Delay:Word;
    CostHp:Word;
    CostMp:Word;
    Action:Word;
    AppendTime:Word;
    AppendType:Word;
  end;

  TAiSetting = record
    MoveStyle:Byte;
    DieStyle:Byte;
    TargetSelect:Byte;
    TargetFlag:Byte;
    ViewDistance:Byte;
    CoolEyes:Byte;
    EscapeDistance:Byte;
    LockDirection:Byte;
  end;

  TPetSetting = record
    pType:Byte;
    StopAt:Byte;
  end;

  TChangeInto = record
    bEnabled:Boolean;
    bShowAnim:Boolean;
    AppendEffect:DWORD;
    ChangeIntoMonster:string;
    Situation1:TChangeSituation;
    Situation2:TChangeSituation;
  end;

  TMonsterClass = class
  public
    Base:TBase;
    Prop:TProp;
    SFlag:TSpecialProp;
    AttackDesc:TAiAttack;
    AiSetting:TAiSetting;
    PetSetting:TPetSetting;
    ChangeInto:array[0..2] of TChangeInto;
    procedure Clear;
    procedure Copy( AMonsterClass:TMonsterClass );
  end;
  TPMonsterClass = ^TMonsterClass;

  procedure Fill256ColorToComboBox( combobox:TComboBox );
  procedure Fill16ColorToComboBox( combobox:TComboBox );
implementation



procedure TMonsterClass.Clear;
begin
  ZeroMemory( @Base, sizeof( TBase ) );
  ZeroMemory( @Prop, sizeof( TProp ) );
  ZeroMemory( @SFlag, sizeof( TSpecialProp ) );
  ZeroMemory( @AiSetting, sizeof( TAiSetting ) );
  ZeroMemory( @PetSetting, sizeof( TPetSetting ) );
  ZeroMemory( @AttackDesc, sizeof( TAiAttack ) );
  ZeroMemory( @ChangeInto, sizeof( TChangeInto ) * 3 );
end;

procedure TMonsterClass.Copy( AMonsterClass:TMonsterClass );
begin
  Base := AMonsterClass.Base;
  Prop := AMonsterClass.Prop;
  SFlag := AMonsterClass.SFlag;
  AiSetting := AMonsterClass.AiSetting;
  PetSetting := AMonsterClass.PetSetting;
  AttackDesc := AMonsterClass.AttackDesc;
  ChangeInto[0] := AMonsterClass.ChangeInto[0];
  ChangeInto[1] := AMonsterClass.ChangeInto[1];
  ChangeInto[2] := AMonsterClass.ChangeInto[2];
end;

